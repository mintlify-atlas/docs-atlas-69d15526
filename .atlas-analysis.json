  "keyFeatures": [
    "Customizable work types via Rails generators",
    "Configurable deposit workflows with Sipity",
    "Flexible M3-based metadata schemas",
    "IIIF manifest generation and image serving",
    "Valkyrie persistence layer with Fedora and PostgreSQL backends",
    "Administrative dashboard for feature toggles and analytics",
    "Blacklight-powered search and discovery",
    "Background job processing for file ingest and derivatives",
    "Access controls with embargoes and leases",
    "Proxy deposit and collection management"
  ],
